# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/jiya-and-associates

# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=admin@yourdomain.com

# Secret admin route — this becomes the URL: /jiya-admin-7x9k2
ADMIN_PATH=jiya-admin-7x9k2

# JWT secret — any long random string (32+ chars)
JWT_SECRET=replace-this-with-a-very-long-random-string

# Admin login credentials
ADMIN_EMAIL=admin@jiyaandassociates.com
# Generate hash: node -e "const b=require('bcryptjs'); b.hash('YourPassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$examplehashgoeshere
